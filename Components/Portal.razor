@implements IDisposable
@inject IJSRuntime JsRuntime

<div id="@Id"
     style="position: absolute;
          z-index: 9999;
          display: @(_wasAppended ? "block" : "none");
      top:@_topPx;
      left:@_leftPx;
      transform:@_transform;
      width:@_resolvedWidth">
    @if (_wasAppended)
    {
        @ChildContent
    }
</div>


@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter, EditorRequired]
    public string TriggerElementId { get; set; } = "";

    [Parameter]
    public bool Show { get; set; }

    [Parameter]
    public string? Width { get; set; }

    [Parameter]
    public DropdownAnchorPosition AnchorPosition { get; set; } = DropdownAnchorPosition.Left;

    [Parameter, EditorRequired]
    public string Id { get; set; } = null!;

    private string _topPx = "0px";
    private string _leftPx = "0px";
    private string _widthPx = "auto";
    private string _resolvedWidth = "auto";
    private string _transform = "none";
    private bool _wasAppended;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Show)
        {
            if (_wasAppended)
                return;

            await Task.Delay(1);

            var pos = await JsRuntime.InvokeAsync<Position?>("portalHelper.getPosition", TriggerElementId, Id);

            if (pos != null)
            {
                _topPx = $"{pos.Top.ToString("F1", CultureInfo.InvariantCulture)}px";
                _leftPx = AnchorPosition switch
                {
                    DropdownAnchorPosition.Center => $"{(pos.Left + (pos.Width / 2d)).ToString("F1", CultureInfo.InvariantCulture)}px",
                    DropdownAnchorPosition.Right => $"{(pos.Left + pos.Width).ToString("F1", CultureInfo.InvariantCulture)}px",
                    _ => $"{pos.Left.ToString("F1", CultureInfo.InvariantCulture)}px"
                };

                var horizontalTransform = AnchorPosition switch
                {
                    DropdownAnchorPosition.Center => "translateX(-50%)",
                    DropdownAnchorPosition.Right => "translateX(-100%)",
                    _ => "none"
                };
                _transform = pos.PlaceAbove
                    ? (horizontalTransform == "none" ? "translateY(-100%)" : $"{horizontalTransform} translateY(-100%)")
                    : horizontalTransform;

                _widthPx = $"{pos.Width.ToString("F1", CultureInfo.InvariantCulture)}px";
                _resolvedWidth = string.IsNullOrWhiteSpace(Width)
                    ? _widthPx
                    : $"calc({_widthPx} + {Width!.Trim()})";

                await JsRuntime.InvokeVoidAsync("portalHelper.appendToBody", Id);
                _wasAppended = true;
            }

            StateHasChanged();
        }
        else if (_wasAppended)
        {
            await JsRuntime.InvokeVoidAsync("portalHelper.removeFromBody", Id);
            _wasAppended = false;
        }
    }

    private class Position
    {
        public double Top { get; init; }
        public double Left { get; init; }
        public double Width { get; init; }
        public bool PlaceAbove { get; init; }
    }

    public void Dispose()
    {
        // TODO release managed resources here
    }
}
